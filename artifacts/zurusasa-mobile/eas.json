{
  "cli": {
    "appVersionSource": "remote"
  },
  "build": {
    "development": {
      "developmentClient": true,
      "distribution": "internal",
      "credentialsSource": "local",
      "android": { "buildType": "apk" },
      "env": {
        "EXPO_PUBLIC_SUPABASE_URL": "PASTE_YOUR_SUPABASE_URL",
        "EXPO_PUBLIC_SUPABASE_PUBLISHABLE_KEY": "PASTE_YOUR_SUPABASE_PUBLISHABLE_KEY",
        "EXPO_PUBLIC_GOOGLE_WEB_CLIENT_ID": "PASTE_YOUR_GOOGLE_WEB_CLIENT_ID"
      }
    },
    "preview": {
      "distribution": "internal",
      "credentialsSource": "local",
      "android": { "buildType": "apk" },
      "env": {
        "EXPO_PUBLIC_SUPABASE_URL": "PASTE_YOUR_SUPABASE_URL",
        "EXPO_PUBLIC_SUPABASE_PUBLISHABLE_KEY": "PASTE_YOUR_SUPABASE_PUBLISHABLE_KEY",
        "EXPO_PUBLIC_GOOGLE_WEB_CLIENT_ID": "PASTE_YOUR_GOOGLE_WEB_CLIENT_ID"
      }
    },
    "production": {
      "autoIncrement": true,
      "credentialsSource": "local",
      "env": {
        "EXPO_PUBLIC_SUPABASE_URL": "PASTE_YOUR_SUPABASE_URL",
        "EXPO_PUBLIC_SUPABASE_PUBLISHABLE_KEY": "PASTE_YOUR_SUPABASE_PUBLISHABLE_KEY",
        "EXPO_PUBLIC_GOOGLE_WEB_CLIENT_ID": "PASTE_YOUR_GOOGLE_WEB_CLIENT_ID"
      }
    }
  },
  "submit": {
    "production": {}
  }
}
