{
  "expo": {
    "name": "ZuruSasa",
    "slug": "zurusasa-mobile",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "zurusasa-mobile",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/images/icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#e86817"
    },
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.zurureels.app"
    },
    "android": {
      "package": "com.zurureels.app"
    },
    "web": {
      "favicon": "./assets/images/icon.png"
    },
    "updates": {
      "url": "https://u.expo.dev/7288bdeb-4a70-4035-9563-587a72f32534"
    },
    "runtimeVersion": {
      "policy": "appVersion"
    },
    "plugins": [
      [
        "expo-router",
        {
          "origin": "https://replit.com/"
        }
      ],
      "expo-font",
      "expo-web-browser",
      "expo-video",
      "@react-native-google-signin/google-signin"
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    },
    "extra": {
      "eas": {
        "projectId": "7288bdeb-4a70-4035-9563-587a72f32534"
      }
    }
  }
}
