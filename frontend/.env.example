# =============================================================
# ZuruReels — Frontend Environment Variables
# Copy this file to .env and fill in your values.
# NEVER commit .env to version control.
# =============================================================

# ── Supabase ─────────────────────────────────────────────────
# Get from: https://supabase.com/dashboard → Project Settings → API
VITE_SUPABASE_URL=https://<your-project-id>.supabase.co
VITE_SUPABASE_PUBLISHABLE_KEY=<your-anon-public-key>

# ── Cloudinary ───────────────────────────────────────────────
# Get from: https://cloudinary.com/console
# VITE_CLOUDINARY_UPLOAD_PRESET must be an *unsigned* preset
# (Settings → Upload → Upload presets → Add unsigned preset)
VITE_CLOUDINARY_CLOUD_NAME=<your-cloud-name>
VITE_CLOUDINARY_UPLOAD_PRESET=<your-unsigned-upload-preset>
